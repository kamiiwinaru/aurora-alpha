{
  "name": "aurora-alpha",
  "version": "1.0.4",
  "description": "Aurora Alpha — Capsuleer Intelligence System for EVE Online",
  "author": "Kami Iwinaru",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"node scripts/open-chrome.js\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "bot": "tsx watch bot/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run server\" \"npm run client\" \"npm run electron:main\"",
    "electron:main": "tsc -p tsconfig.electron.json && electron dist-electron/main.js",
    "electron:build": "cross-env ELECTRON=true vite build && tsc -p tsconfig.electron.json && node scripts/build-server.mjs && electron-builder",
    "electron:publish": "cross-env ELECTRON=true vite build && tsc -p tsconfig.electron.json && node scripts/build-server.mjs && electron-builder --publish always"
  },
  "build": {
    "appId": "com.aurora.eve",
    "productName": "Aurora Alpha",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-server",
        "to": "server",
        "filter": [
          "index.js"
        ]
      },
      {
        "from": "public",
        "to": "public",
        "filter": [
          "aurora-icon.png",
          "aurora-icon.ico"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/aurora-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aurora Alpha"
    },
    "publish": {
      "provider": "github",
      "owner": "kamiiwinaru",
      "repo": "aurora-alpha"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.25.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/electron": "^1.4.38",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.39",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
